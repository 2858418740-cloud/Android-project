<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_page">

    <!-- 大图 Banner -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardElevation="4dp"
        app:cardCornerRadius="16dp">

        <ImageView
            android:id="@+id/iv_shop_banner"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:src="@drawable/nailong_logo"
            android:scaleType="centerCrop"/>
    </androidx.cardview.widget.CardView>

    <!-- 信息区 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="4dp"
        app:cardElevation="1dp"
        app:cardCornerRadius="14dp"
        app:cardBackgroundColor="@color/bg_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tv_header_dine_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="堂食"
                    android:textColor="#B8860B"
                    android:background="@drawable/shape_btn_light"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_header_shop_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="店铺名称"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginStart="10dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_header_rating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐4.8"
                    android:textColor="@color/tag_orange"
                    android:textSize="13sp"
                    android:layout_marginEnd="10dp"/>

                <View android:layout_width="1dp" android:layout_height="14dp" android:background="@color/divider" android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/tv_header_sales"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="月售9999"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginEnd="10dp"/>

                <View android:layout_width="1dp" android:layout_height="14dp" android:background="@color/divider" android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/tv_header_delivery_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="约30min"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginEnd="10dp"/>

                <View android:layout_width="1dp" android:layout_height="14dp" android:background="@color/divider" android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/tv_header_rank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏅第1名"
                    android:textColor="@color/text_hint"
                    android:textSize="13sp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_header_promotion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏷️ 满30减5"
                android:textColor="@color/accent_red"
                android:textSize="12sp"
                android:layout_marginTop="6dp"
                android:visibility="gone"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
